# Supabase project credentials (Project Settings -> API). Resolved at build time.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Demo mode: when true, enforces a hard product cap and shows ad slots.
# Leave false (or unset) for a normal self-hosted install with no limits.
VITE_DEMO_MODE=false
VITE_DEMO_MAX_PRODUCTS=15
