# Supabase project credentials (Project Settings -> API). Resolved at build time.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Demo mode: shows the anonymous "try it" entry on the login page (needs
# "Allow anonymous sign-ins" enabled in Supabase). Leave false for self-host.
# Per-user limits are configured in the app_config table, not here (see 0006).
VITE_DEMO_MODE=false

# Cloudflare Turnstile CAPTCHA (public site key). When set, the login page shows
# the widget and sends the token to Supabase. Must pair with the widget's SECRET
# key configured in Supabase → Authentication → Attack Protection. Leave empty
# to disable CAPTCHA (self-host).
VITE_TURNSTILE_SITE_KEY=

# Shows the side ad slots in the app area (hosted instance only). The slots are
# placeholders until an ad network snippet is added in AdSlot.tsx. Leave false
# for self-host.
VITE_ADS_ENABLED=false

# Cloudflare Web Analytics token (cookieless traffic metrics). Create the site
# in the Cloudflare dashboard (Analytics & Logs → Web Analytics) and paste the
# token here. Leave empty for self-host — no analytics script is loaded.
VITE_CF_ANALYTICS_TOKEN=
